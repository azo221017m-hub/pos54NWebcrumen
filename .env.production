# Variables de entorno para producción (Vite las carga durante npm run build)
# Estos valores se embeben en el JavaScript compilado.
# Se pueden sobreescribir con variables de entorno del sistema en la plataforma de deploy.

# URL del backend API (SIN /api al final - se agrega automáticamente en api.config.ts)
VITE_API_URL=https://pos54nwebcrumenbackend.onrender.com

# Nombre de la aplicación
VITE_APP_NAME=Web POS Crumen

# Timeout para peticiones API (ms)
VITE_API_TIMEOUT=30000
