# Variables de entorno para Frontend

# URL de la API backend (SIN /api al final - se agrega automáticamente)
VITE_API_URL=http://localhost:3000

# Nombre de la aplicación
VITE_APP_NAME=Web POS Crumen

# Timeout para peticiones API (ms)
VITE_API_TIMEOUT=10000

# Modo debug
VITE_DEBUG=true

# NOTA: La URL de WebSocket se deriva automáticamente de VITE_API_URL
# (http -> ws, https -> wss, + ruta /ws)
# No es necesario configurar VITE_WS_URL a menos que el WS esté en un host diferente.
